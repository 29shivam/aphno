# ── API (apps/api/.env) ──────────────────────────────────────────────
# Pooled connection for the app; DIRECT_URL (unpooled) is used by migrations.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
# Secret for signing auth JWTs (min 16 chars). MUST be overridden in production.
JWT_SECRET=change-me-to-a-long-random-string
# Optional overrides (defaults shown):
# JWT_TTL_SEC=2592000        # 30 days
# OTP_TTL_SEC=300            # 5 minutes
# OTP_MAX_ATTEMPTS=5
# Twilio SMS for OTP delivery (optional — if unset, codes are logged, not sent).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── DB (packages/db/.env) ────────────────────────────────────────────
# The db package needs DATABASE_URL + DIRECT_URL for Prisma CLI/migrations.

# ── Mobile/web (apps/mobile/.env) ────────────────────────────────────
# EXPO_PUBLIC_* vars are readable client-side and inlined at build time.
# A physical device / APK cannot reach "localhost" — use a LAN IP or deployed URL.
EXPO_PUBLIC_API_URL=http://localhost:4000
