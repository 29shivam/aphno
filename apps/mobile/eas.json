{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_USE_METRO_WORKSPACE_ROOT": "1" }
    },
    "preview": {
      "distribution": "internal",
      "env": { "EXPO_USE_METRO_WORKSPACE_ROOT": "1" },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EXPO_USE_METRO_WORKSPACE_ROOT": "1" },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
