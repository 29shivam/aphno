# Copy to apps/mobile/.env and fill in the values (.env is gitignored).

# API base URL. localhost works for web dev; a physical device / installed APK
# cannot reach "localhost" — use your machine's LAN IP or a deployed API URL.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Google OAuth Web client ID (public — bundled into the client). Create it in the
# Google Cloud Console → Credentials, and use the SAME value for GOOGLE_CLIENT_ID
# on the API, or the backend rejects the token's audience.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
