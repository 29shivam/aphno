{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --config.node-linker=hoisted",
  "buildCommand": "pnpm --filter @aphno/mobile run web:export",
  "outputDirectory": "apps/mobile/dist",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
