{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --config.node-linker=hoisted",
  "buildCommand": "cd apps/mobile && pnpm exec expo export --platform web --output-dir dist",
  "outputDirectory": "apps/mobile/dist",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
